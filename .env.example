# PostgreSQL connection string (required)
# For Neon, use the POOLED URL (hostname ends with "-pooler").
DATABASE_URL=postgresql://user:password@host:5432/resume_builder

# Flask session secret (required in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Fernet encryption key for API key storage (required in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Port (Railway/Fly set this automatically)
PORT=8000
