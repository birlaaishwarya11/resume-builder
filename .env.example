# PostgreSQL connection string (required)
# Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@localhost:5432/resume_builder

# Flask session secret (required in production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Fernet encryption key for API key storage (required in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Data directory for per-user files (default: ./data)
# On Railway, mount a persistent volume and point this there
DATA_DIR=/app/data

# Port (Railway sets this automatically)
PORT=8000
